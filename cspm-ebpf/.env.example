# Sentinel-Core Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================================
# Pinecone Configuration (Required)
# ===========================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=your_pinecone_environment_url_here

# ===========================================
# Google AI Configuration (Required)
# ===========================================
# Used for both embeddings (embedding-004) and LLM (gemini-1.5-pro)
GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# Embedding Provider Selection
# ===========================================
# Options: "google" (default) or "openai"
EMBEDDING_MODEL=google

# ===========================================
# OpenAI Configuration (Only if EMBEDDING_MODEL=openai)
# ===========================================
# OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# LLM Configuration (Orchestrator)
# ===========================================
# Google Gemini model for report generation
LLM_MODEL=gemini-1.5-pro

# ===========================================
# API Security (Optional — skip for dev mode)
# ===========================================
# If set, the /analyze endpoint requires X-Sentinel-Key header
# SENTINEL_API_KEY=your_secret_api_key_here

# ===========================================
# Infrastructure (Optional)
# ===========================================
# TETRAGON_GRPC_ADDRESS=localhost:50001
# API_PORT=8081
