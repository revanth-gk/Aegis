# Sentinel-Core Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================================
# Pinecone Configuration (Required)
# ===========================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_HOST=your_pinecone_index_host_url_here

# Used for LLM generation (fallback chain)
# You can provide up to 3 keys to prevent quota exhaustion
GOOGLE_API_KEY=your_primary_google_api_key_here
GOOGLE_API_KEY_2=your_secondary_google_api_key_here
GOOGLE_API_KEY_3=your_tertiary_google_api_key_here

# ===========================================
# LLM Configuration (Orchestrator)
# ===========================================
# Google Gemini model for incident report generation
LLM_MODEL=gemini-2.0-pro
# Fallback model if primary exceeds quota or fails
LLM_MODEL_FALLBACK=gemini-2.0-flash

# ===========================================
# Redis Configuration (Optional)
# ===========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_CHANNEL=sentinel_events

# ===========================================
# API Security (Optional — skip for dev mode)
# ===========================================
# If set, the /analyze endpoint requires X-Sentinel-Key header
# SENTINEL_API_KEY=your_secret_api_key_here

# ===========================================
# Infrastructure (Optional)
# ===========================================
# TETRAGON_GRPC_ADDRESS=localhost:50001
# API_PORT=8081
# OFFLINE_MODE=false