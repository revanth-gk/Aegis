# RemediationAgent Configuration Example
# Copy this file to .env and customize for your environment

# ============================================================================
# AUTONOMY MODE
# ============================================================================
# Controls human approval requirements for remediation actions
# Options:
#   - "autonomous": Execute all approved actions without confirmation
#   - "tiered": Execute YAML without confirmation, require confirmation for SIGKILL
#   - "human-in-loop": Require confirmation for all actions
# Default: "tiered"
REMEDIATION_AUTONOMY_MODE=tiered

# ============================================================================
# DRY RUN MODE
# ============================================================================
# If true, log actions without executing kubectl commands
# Recommended: true for initial testing, false for production
# Default: true
REMEDIATION_DRY_RUN=true

# ============================================================================
# CONFIDENCE THRESHOLDS
# ============================================================================
# Minimum confidence scores (0.0-1.0) required for action approval

# SIGKILL (process termination) threshold
# Higher threshold = more conservative (fewer false positives)
# Default: 0.92
REMEDIATION_SIGKILL_THRESHOLD=0.92

# YAML (resource patch) threshold
# Higher threshold = more conservative
# Default: 0.95
REMEDIATION_YAML_THRESHOLD=0.95

# ============================================================================
# KUBERNETES AUTHENTICATION
# ============================================================================
# Path to kubeconfig file for external cluster authentication
# Leave empty or comment out to use in-cluster ServiceAccount authentication
# Default: None (in-cluster auth)
# KUBECONFIG_PATH=/path/to/kubeconfig

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis connection settings for audit trail storage

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password  # Uncomment if Redis requires authentication

# ============================================================================
# LOGGING
# ============================================================================
# Log level for remediation agent
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO
